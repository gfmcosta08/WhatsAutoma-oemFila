PORT=3000
NODE_ENV=production
DATABASE_URL=postgresql://user:pass@host:5432/dbname
REDIS_URL=redis://localhost:6379

WEBHOOK_BASE_URL=https://seudominio.com
CORS_ORIGIN=

ADMIN_PASSWORD=
ADMIN_SESSION_SECRET=
SETTINGS_ENCRYPTION_KEY=
INTERNAL_NOTIFY_SECRET=

# auto | uazapi | meta — auto escolhe UazAPI se houver token de instância
WHATSAPP_PROVIDER=auto
# Opcional: se o webhook mandar só DDD+número (10–11 dígitos), prefixa DDI antes de enviar (ex.: Brasil = 55)
WHATSAPP_DEFAULT_CC=

# UazAPI — doc: https://docs.uazapi.com | Base típica produção: https://SEU_SUBDOMINIO.uazapi.com | homologação: https://free.uazapi.dev
UAZAPI_BASE_URL=https://free.uazapi.dev
# auto = header em *.uazapi.dev (uazapiGO v2); query = ?token=&admintoken= (legado / igual n8n)
UAZAPI_AUTH_MODE=auto
UAZAPI_INSTANCE_TOKEN=
UAZAPI_ADMIN_TOKEN=
UAZAPI_INSTANCE_PHONE=

# Legado Meta Cloud API (só com WHATSAPP_PROVIDER=meta)
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=

ENABLE_AGENDAMENTO=true
SUPERADMIN=false
